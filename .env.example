OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
EMAIL_USERNAME=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# Optional: Custom API base URLs (for proxies, Azure OpenAI, etc.)
# OPENAI_BASE_URL=https://api.openai.com/v1
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Optional config overrides (useful for GitHub Actions repo variables)
ARXIV_CATEGORIES=cs.AI,cs.CL,cs.LG,cs.CV
ARXIV_MAX_RESULTS_PER_CATEGORY=500
ARXIV_CUTOFF_DAYS=1
LLM_PROVIDER=claude_code
EMAIL_ENABLED=true
EMAIL_FROM=your-email@gmail.com
EMAIL_TO=your-email@gmail.com
EMAIL_SUBJECT_PREFIX=[Daily Papers]
REPORT_CHINESE=true
DATABASE_PATH=data/papers.db
